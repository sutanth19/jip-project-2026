{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",

    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"]
}