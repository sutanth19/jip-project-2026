generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String        @id @default(uuid()) @db.Uuid
  role                UserRole
  email               String?       @unique
  passwordHash        String?
  accountStatus       AccountStatus @default(PENDING)
  isFirstLogin        Boolean       @default(true)
  lastLogin           DateTime?
  passwordResetToken  String?       @unique
  passwordResetExpiry DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  setupToken          String?       @unique
  setupTokenExpiry    DateTime?
  admin               Admin?
  parent              Parent?
  student             Student?
  teacher             Teacher?

  @@map("users")
}

model School {
  id            String        @id @default(uuid()) @db.Uuid
  schoolCode    String        @unique
  schoolName    String        @unique
  logo          String?
  principalName String?
  address       String
  phone         String
  contactEmail  String?       @unique
  accountStatus AccountStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  admins        Admin[]
  parents       Parent[]
  classes       SchoolClass[]
  students      Student[]
  teachers      Teacher[]

  @@map("schools")
}

model Teacher {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @unique @db.Uuid
  schoolId      String        @db.Uuid
  teacherId     String        @unique
  fullName      String
  gender        Gender
  phone         String?       @unique
  position      String?
  avatar        String?
  accountStatus AccountStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  classes       SchoolClass[]
  school        School        @relation(fields: [schoolId], references: [id])
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([teacherId])
  @@map("teachers")
}

model SchoolClass {
  id            String        @id @default(uuid()) @db.Uuid
  schoolId      String        @db.Uuid
  teacherId     String        @db.Uuid
  className     String
  yearLevel     Int
  academicYear  Int
  capacity      Int?
  accountStatus AccountStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  school        School        @relation(fields: [schoolId], references: [id])
  teacher       Teacher       @relation(fields: [teacherId], references: [id])
  students      Student[]

  @@unique([schoolId, className, academicYear])
  @@index([schoolId])
  @@index([teacherId])
  @@map("school_classes")
}

model Student {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @unique @db.Uuid
  schoolId      String          @db.Uuid
  classId       String          @db.Uuid
  studentId     String          @unique
  fullName      String
  gender        Gender
  birthDate     DateTime?
  pinHash       String
  avatar        String?
  accountStatus AccountStatus   @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  isPinChanged  Boolean         @default(false)
  pinUpdatedAt  DateTime?
  parents       ParentStudent[]
  class         SchoolClass     @relation(fields: [classId], references: [id])
  school        School          @relation(fields: [schoolId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([classId])
  @@index([studentId])
  @@map("students")
}

model Parent {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @unique @db.Uuid
  schoolId      String          @db.Uuid
  fullName      String
  phone         String          @unique
  occupation    String?
  address       String?
  avatar        String?
  accountStatus AccountStatus   @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  students      ParentStudent[]
  school        School          @relation(fields: [schoolId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("parents")
}

model ParentStudent {
  id           String             @id @default(uuid()) @db.Uuid
  parentId     String             @db.Uuid
  studentId    String             @db.Uuid
  relationship ParentRelationship
  createdAt    DateTime           @default(now())
  parent       Parent             @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student      Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
  @@map("parent_students")
}

model Admin {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @unique @db.Uuid
  schoolId      String?       @db.Uuid
  fullName      String
  phone         String?
  position      String?
  avatar        String?
  accountStatus AccountStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  school        School?       @relation(fields: [schoolId], references: [id])
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("admins")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum AccountStatus {
  ACTIVE
  PENDING
  LOCKED
  SUSPENDED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
}

enum ParentRelationship {
  FATHER
  MOTHER
  GUARDIAN
}
